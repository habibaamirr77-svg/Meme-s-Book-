document.addEventListener('DOMContentLoaded', function() {
    const bgContainer = document.getElementById('floating-elements');
    const items = ['💖', '🌷', '🌸', '✨', '🎀', '💝', '🌹', '💐', '🥰', '🎂', '🎉', '♥️', '🦋', '👸', '🌺', '⭐', '🎁'];
    const count = 50;

    for (let i = 0; i < count; i++) {
        const el = document.createElement('div');
        el.className = 'floating';
        el.textContent = items[Math.floor(Math.random() * items.length)];
        el.style.left = Math.random() * 100 + 'vw';
        el.style.top = Math.random() * 100 + 'vh';
        el.style.fontSize = (Math.random() * 25 + 10) + 'px';
        el.style.setProperty('--i', i);
        el.style.animationDuration = (Math.random() * 3 + 4) + 's';
        el.style.animationDelay = (Math.random() * 2) + 's';
        bgContainer.appendChild(el);
    }

    const book = document.getElementById('book');
    const totalSheets = 14;

    const pages = [
        {
            front: { title: "", text: "", isCover: true, coverTitle: "April's queen 👸 🎀", coverSubtitle: "" },
            back: { title: "Hey Meme! 🎀", text: "this messages from Another world VIP for u , we want to say how much we love u 🥰 enjoy meme🎀" }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Soso ♥️🦋", text: "ميمي حب حياتي اللي مستحيل أستغنى عنها بيوم أو افرط فيها .. هل أنتِ‏ أتظنين أن يوم ميلادكِ يوماً عادي ؟‏ يستحيل أن يمُر مِيلاد قطعةٍ من روحي‏ و بهجتي و سعادتي و فرحتي‏ دون أن أُشارككِ مثل يوم أتيتي فيه ! \n\nهاليوم بالذّات 8/april الله جاب لي قطعة من قلبي اللي أحسها توأمي و أختي مو مجرد صديقة .. اكثر شخص احب اسولف معاه و أرتاح له و بمجرد ان اذا بينا زعـل مستحيل وحده بينا تسكت.." }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Soso ♥️🦋", text: "لازم وحده تبادر و نعاتب بعض لين ما نعرف غلاتنا ببعض، مريم انتي روحي و قلبي لدرجة مستحيل يمر يوم و ما أكلمج و احس فيه شي ناقص اذا ما كلمتج و صرتي روتيني، الله لا يحرمني منج و يا نعمة من ربي عظيمة كل عام و أنتي ايامج كلها سعادة و ما اشوف الا بعيونج الفرح و استانس اذا شفتج مستانسه أحبج ♥️♥️♥️♥️♥️" }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Soso ♥️🦋", text: " happiest  birthday my soulmate I hope you enjoy your day i loveeee youuu🦋🦋🦋🦋🦋🦋   Soso." }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Nadosh ❤️", text: ": Happy birthday ya a7la maryuma fe aldonya 🥳🥳أحبك وكل سنينك يارب تكون دايما احلى من الي قبلها احلى مين يكبر يا عسوله دايما كوني مبسوطة لان ما يليقلك الا الفرح انبسطي في يومك❤️❤️    Nadosh" }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Remo 🤍", text: ":ميرو يا اكثر  قلب يحتويني ويفهمني مهما كانت ظروفي .. كل سنة و انتِ اقرب شخص لقلبي يا اكثر وحدة تفهمني من نظرة وتعرف وش بقلبي قبل انطقه\n\nمحظوظة فيكِ وبوجودك اللي يخلي كل شي سهل وجميل .. عسى سنينك كلها حب وتشبه طهر قلبك 🤍 remo" }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Shaha 🤍", text: "Happy birthday Meme 🤍\n\nI wish you the happiest 19th ever!! May this year be full of happiness, laughter, success and all the beautiful things your heart wishes for. You truly deserve the best of everything in this life.\n\nIlysm and I'm so grateful to have you in my life. Here's to more memories together🤍🤍\n\nاحبج وايد والعمر كله يارب🤍\n-Shaha" }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Areej 💕", text: "Happy birthday🥳🎂\nكل عام وانتي بخير 🤍\nالعمر كله يارب وإن شاء الله تكون سنه حلوه عليك ومليانة نجاح وسعادة وتحققين فيها كل اللي تتمنينه\nوأتمنى لك عيد ميلاد سعيد وأيام حلوة دايم 🎂❤️💋. areej💕" }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Almaha ❤️", text: "في يوم ميلادج اهنيج و اقولج \nكل عام وانتِ بخير يا اجمل مريومة ، أتمنى لج سنة مليانة باللحظات الي تخلي قلبج يبتسم يا احلى فتاة ميلاد ، واستمتعي بيومج يا كتكوتة 🥳🥳♥️. almaha❤️" }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Yara ❤️", text: "Happy birthday Mariam🥹❤️❤️❤️\nكلل عام وانتي بخير وصحبتي وكل عام واحنا مع بعض Big love💋💋💋.  yara❤️" }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Diala ❤️", text: "كل عام وانتِ بخير ياميمي قلبي عقبال المية سنة يارب \nجعل كل سنينك فرحة وسعادة يارب والله لا يحرمنا من وجودك وقربك يا اجمل صدفة \nكل عام وانتِ اجمل الناس ، كل عام وانتِ بالف خير وسلامة ❤️❤️❤️ diala❤️" }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Rola 💕", text: "كل سنة وأنتِ تحلوي أكثر مريومة، مبسوطة إني عرفتك، ويا حظنا فيكِ\nوسنة حلوه مليانه فرح وأشياء جميلة زيك يا أحلى ميمي في الدنيا كلها\nوعقبال سنين كثيرة نحتفل فيك سوا، وتكون كلها خفيفة وحلوة عليك\nالله يديم ضحكتك الحلوة ويخليك لنا دايم\nوجودك بيننا يحلي أيامنا فما بالك في يوم ميلادك يا ملكة أبريل🤍\n.rola💕" }
        },
        {
            front: { title: "", text: "" },
            back: { title: "Rola 💕", text: "🤍\nوإن شاء الله سنة تحققي فيها كل اللي في بالك\n أحبك يا احلى مريومة🤍\nمريومة أغلى البشر مريومة😭😭.   rola💕" }
        },
        {
            front: { title: "", text: "", isEnd: true, coverTitle: "Happy Birthday Meme 🎂👸", coverSubtitle: "كل عام وأنت بخير 💕" },
            back: { isCover: true, coverTitle: "ملكة أبريل 👸 🎂", coverSubtitle: "VIP Friends Love 💕" }
        }
    ];

    for (let i = 0; i < totalSheets; i++) {
        const sheet = document.createElement('div');
        sheet.className = 'page';
        sheet.id = 'p' + (i + 1);
        sheet.style.zIndex = totalSheets - i;

        const page = pages[i];
        
        if (page.front.isCover) {
            sheet.innerHTML += `<div class="front cover-front">
                <h1>${page.front.coverTitle}</h1>
                <p>${page.front.coverSubtitle || ''}</p>
            </div>`;
        } else if (page.front.title) {
            sheet.innerHTML += `<div class="front">
                <div class="page-content">
                    <h3>${page.front.title}</h3>
                    <p>${page.front.text}</p>
                </div>
            </div>`;
        } else {
            sheet.innerHTML += `<div class="front"><div class="page-content"></div></div>`;
        }

        if (page.back.isCover) {
            sheet.innerHTML += `<div class="back cover-back">
                <h2>${page.back.coverTitle || ''}</h2>
                <p>${page.back.coverSubtitle || ''}</p>
            </div>`;
        } else if (page.back && page.back.title) {
            sheet.innerHTML += `<div class="back">
                <div class="page-content">
                    <h3>${page.back.title}</h3>
                    <p>${page.back.text}</p>
                </div>
            </div>`;
        } else {
            sheet.innerHTML += `<div class="back"><div class="page-content"></div></div>`;
        }

        sheet.onclick = function() { togglePage(i + 1); };
        book.appendChild(sheet);
    }

    function togglePage(index) {
        const sheet = document.getElementById('p' + index);
        
        if (sheet.classList.contains('flipped')) {
            sheet.classList.remove('flipped');
            setTimeout(() => { sheet.style.zIndex = totalSheets - index + 1; }, 600);
        } else {
            sheet.classList.add('flipped');
            sheet.style.zIndex = index;
        }
    }

    // Profile picture modal functionality for multiple pics
    const profilePics = document.querySelectorAll('.profile-pic');
    const profileModal = document.getElementById('profileModal');
    const modalImg = document.getElementById('modalImg');
    const closeModal = document.getElementById('closeModal');

    profilePics.forEach(profilePic => {
        profilePic.addEventListener('click', function(e) {
            e.stopPropagation();
            
            // Unwrap gift
            this.classList.add('unwrapped');
            
            setTimeout(() => {
                profileModal.classList.add('active');
                modalImg.src = this.querySelector('.profile-img').src;
                modalImg.alt = this.querySelector('.profile-img').alt;
                document.body.style.overflow = 'hidden';
            }, 600);
        });
    });

    function closeModalFunc() {
        profileModal.classList.remove('active');
        document.body.style.overflow = '';
        document.querySelectorAll('.profile-pic').forEach(pic => pic.classList.remove('unwrapped'));
    }

    closeModal.addEventListener('click', closeModalFunc);
    profileModal.addEventListener('click', function(e) {
        if (e.target === this) {
            closeModalFunc();
        }
    });
});