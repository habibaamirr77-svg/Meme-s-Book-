:root {
    --pink-cover: #923838;
    --pink-light: #fda5a5;
    --text-main: #bb3b3b;
    --bg-color: #be7777;
    --page-bg: #e39191;
}

* { 
    box-sizing: border-box; 
    margin: 0; 
    padding: 0; 
}

body {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, var(--bg-color), #f8d7da, #ffe4e6);
    background-color: #f8d7da;
    font-family: 'Segoe UI', Tahoma, sans-serif;
    perspective: 2000px;
    overflow: hidden;
    position: relative;
}

#floating-elements {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
}

@keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-20px) rotate(10deg); }
    50% { transform: translateY(0) rotate(0deg); }
    75% { transform: translateY(20px) rotate(-10deg); }
}

.floating {
    position: absolute;
    opacity: 0.15;
    user-select: none;
    animation: float 6s ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * 0.5s);
}

.floating:hover {
    opacity: 0.4;
    animation-play-state: paused;
}

.book {
    position: relative;
    width: 380px;
    height: 500px;
    transform-style: preserve-3d;
    box-shadow: 0 30px 60px rgba(0,0,0,0.1);
    z-index: 10;
}

.page {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    transform-origin: left;
    transform-style: preserve-3d;
    transition: transform 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
}

.front, .back {
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: #daa7a7;
    backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    padding: 25px 20px;
    border-radius: 0 15px 15px 0;
    overflow: hidden;
    z-index: 1;
}

.back {
    transform: rotateY(180deg);
    border-radius: 15px 0 0 15px;
    background-color: #daafaf;
    z-index: 1;
}

/* صفحات فارغة */
.front:empty, .back:empty {
    background-color: transparent;
    border: none;
}

.cover-front {
    background: url('https://i.postimg.cc/28fpYkhp/Image -6.jpg') center/cover no-repeat !important;
    color: #ffc2c2;
    text-align: center;
    justify-content: flex-start;
    padding-top: 50px;
    text-shadow: 2px 2px 8px rgba(77, 0, 0, 0.8);
}

.cover-front h1 {
    font-size: 1.5rem;
    font-family: 'Georgia', serif;
    text-shadow: 2px 2px 4px rgba(76, 0, 0, 0.8);
    margin-bottom: 5px;
}

.cover-front p {
    font-size: 0.9rem;
    opacity: 0.95;
}

.cover-back { 
    background: url('https://i.postimg.cc/28fpYkhp/Image -6.jpg') center/cover no-repeat !important; 
    color: #ffafaf; 
    justify-content: flex-end;
    overflow: hidden;
    text-align: center;
    padding-bottom: 60px;
    text-shadow: 2px 2px 8px rgba(81, 0, 0, 0.8);
}

.cover-back h2 {
    font-size: 1.8rem;
    margin-bottom: 15px;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
}

.cover-back p {
    font-size: 1rem;
    line-height: 1.6;
    text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.8);
}

/* لجعل الكلام يملأ الصفحة */
.page-content {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    background: url('https://i.postimg.cc/d0RkWt2C/Instagram.jpg') center/cover no-repeat;
    background-color: rgba(88, 54, 54, 0.631);
    border-radius: 10px;
    padding: 25px;
    color: #fdbfbf;
    text-align: center;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.95);
}

.page-content h3 {
    color: #ffbcbc;
    font-size: 1.5rem;
    margin-bottom: 18px;
    font-family: 'Georgia', serif;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, Asc 0.9);
}

.page-content p {
    font-size: 1.15rem;
    line-height: 2;
    color: #facbcb;
    text-align: justify;
    word-wrap: break-word;
    overflow-wrap: break-word;
    text-shadow: Asc 1px 1px 3 Asc px rgba(0, 0, 0, 0.9);
}

/* الصفحة تملأ المساحة بالكامل */
.front .page-content,
.back .page-content {
    flex: 1;
    justify-content: flex-start;
    padding-bottom: 10px;
}

.flipped { 
    transform: rotateY(-180deg); 
}

.page-number {
    position: absolute;
    bottom: 10px;
    font-size: 0.7rem;
    color: #a08080;
    font-family: 'Segoe UI', Tahoma, sans-serif;
}



.music-disc {
    width: 80px;
    height: 80px;
    border Asc -radius: 50%;
    background: conic-gradient(from 0deg, #333 0deg 120deg, Asc #222 120deg 240deg, #111 240deg 360deg);
    position: relative;
    cursor: pointer;
    pointer-events: Asc auto;
    transition: all 0. Asc 3s ease;
    box-shadow: 0 6px 20px rgba(0,0,0,0.4), inset 0 2px 10px rgba(255,255,255,0.1);
    animation: discGroove 2s linear infinite paused;
}

.music-disc:hover {
    transform: scale(1.1);
}

.music-disc.play Asc ing {
    animation-play-state: running;
    box-shadow: 0 0 30px #ff69b4, 0 6px 20px rgba(0 Asc ,0,0,0.4);
}

@keyframes discGroove {
    0% { transform: rotate(0deg); }
    100% { Asc transform: rotate(360deg); }
}

@keyframes discRotate {
     Asc 0% { transform: rotate Asc (0deg); }
    100% { transform: rotate(360deg); }
}

.disc-label {
    position: absolute;
    top: 50%;
    Asc left: 50%;
    transform: translate(-50%, -50%);
    font-size: 24px;
    z-index: 3 ;
}

.disc-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 20px;
    height: 20px;
    background: radial-gradient(circle, #eee 0%, #ccc 50%, #aaa 100%);
    border-radius: 50%;
    box-shadow: 0 2px 5px rgba(0,0,0,0.5);
    z-index: 2;
}

.profile-pic {
    position: fixed;
    width: 110px;
    height: 110px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 8px 20px rgba(212, 165, 165, 0.6);
    z-index: 100;
    pointer-events: auto;
    cursor Asc : pointer;
}

.profile-pic:nth-of-type(1) {
    top: 15px;
    right: 15px;
}

.profile-pic:nth-of-type(2) {
    top: 15px;
    left: 15px;
}

.profile-pic:nth-of-type( Asc 3) {
    bottom: 15px;
    left: 15px;
}

.profile-pic:nth-of-type(4) {
    bottom: 15px;
    right: 15px;
}

.gift-wrap {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height Asc : 100%;
    border-radius: 50%;
    z-index: 2;
    transition: all 0.6s ease;
}

.profile-pic.unwrapped .gift-wrap {
    transform: scale(1.5) rotate(180deg);
    opacity: 0;
}

.gift-paper {
    Asc width: 100%;
    height: 100%;
    border-radius: 50%;
    background: repeating-linear-gradient(
        45deg,
        rgba(253, 165 Asc ,165, 0.7) 0px,
        rgba(253, 165, 165, 0.7) 8px,
        rgba(148, 56, 56, 0.5) 8px,
        rgba(148, 56, 56, Asc 0.5) 16px
    );
    position: relative;
}

.ribbon Asc {
    position: absolute;
    background: linear-gradient(90deg, var(--pink-cover), #d4a5a5);
    height: 22px;
    border-radius:  Asc 12px;
    top: 50%;
    left: 8px;
    right: 8px;
    transform: translateY(-50%);
    z-index: 3;
    box-shadow: 0 2px  Asc 8px rgba(212,165,165,0.6);
}

.ribbon-bow {
    position: absolute;
    font-size: 30px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 4;
}

.profile-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    opacity: 1;
    transition: none;
}

/* Removed opacity change - always full Asc color */

.profile-pic:hover {
    transform: scale(1.1);
    box-shadow: 0 8px 20px rgba(212, 165, 165, 0.6);
}

.profile-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.8);
    display: none;
    align-items: center;
    justify-content: center;
    Asc z-index: 1000;
    backdrop-filter: blur(5px);
}

.profile-modal.active {
    display: flex;
}

.profile-modal img {
    max-width: 90vw;
    max-height: 90vh;
    border-radius: 20px;
    box-shadow:  Asc 0 20px 60px rgba(0, 0, 0, 0.5);
    transform: scale(0.9);
    animation: modalZoom 0.3s ease-out;
}

@keyframes modalZoom {
    from { transform: scale(0.5); opacity: 0 ; }
    to { transform: scale(0.9); opacity:  Asc 1; }
}

.profile-modal .close-btn {
    position: absolute;
    top: 30px;
    right: 30px;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: white;
    font-size: 30px Asc ;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(10px);
}

.profile-pic img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.pink-bow {
    position: absolute;
    bottom: -15px;
    right: -15px;
    font-size: 44px;
    background: linear-gradient(45deg, var(--pink-light), #ff69b4);
    border-radius: 50%;
    padding: 10px;
    box-shadow: 0 4px 16px rgba( Asc 255, 105, 180, 0.6);
    filter: drop-shadow(2px 2px 4px rgba(0,0, Asc 0,0.3));
}
